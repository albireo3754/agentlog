{
  "name": "agentlog",
  "version": "0.1.0",
  "description": "Claude Code prompts → Obsidian Daily Note auto-logger",
  "type": "module",
  "bin": {
    "agentlog": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun build src/cli.ts src/hook.ts --outdir dist --target bun",
    "dev": "bun run src/cli.ts",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  }
}
